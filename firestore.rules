rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════
    // UMUMIY FUNKSIYALAR
    // ═══════════════════════════════════════════════════════
    
    // Foydalanuvchi tizimga kirganmi?
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Yangi hujjat tarkibini tekshirish
    function incomingData() {
      return request.resource.data;
    }
    
    // Mavjud hujjat ma'lumotlari
    function existingData() {
      return resource.data;
    }
    
    // Foydalanuvchi o'zimi?
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ═══════════════════════════════════════════════════════
    // 1. FOYDALANUVCHILAR (Users)
    // ═══════════════════════════════════════════════════════
    match /users/{userId} {
      // Faqat o'zi o'qiy oladi
      allow read: if isSignedIn() && isOwner(userId);
      
      // Faqat o'zi yoza oladi, lekin role maydonini bir marta belgilagandan keyin o'zgartira olmaydi
      allow create: if isSignedIn() && isOwner(userId)
                    && incomingData().keys().hasAll(['name', 'role'])
                    && incomingData().role in ['client', 'barber'];
      
      // Update: `role` ni o'zgartirish taqiqlangan (injection himoya)
      allow update: if isSignedIn() && isOwner(userId)
                    && incomingData().role == existingData().role;
      
      // O'chirish mumkin emas (admin orqali)
      allow delete: if false;
    }
    
    // ═══════════════════════════════════════════════════════
    // 2. SARTAROSHLAR (Barbers)
    // ═══════════════════════════════════════════════════════
    match /barbers/{barberDocId} {
      // Hammaga o'qish ruxsat (ro'yxat uchun)
      allow read: if true;
      
      // Yangi sartarosh: uid majburiy, name va services kerak
      allow create: if isSignedIn() 
                    && incomingData().uid == request.auth.uid
                    && incomingData().keys().hasAll(['uid', 'name', 'services']);
      
      // Yangilash: uid ni o'zgartirish mumkin emas
      allow update: if isSignedIn() 
                    && existingData().uid == request.auth.uid 
                    && incomingData().uid == existingData().uid;
                    
      // O'chirish: faqat hujjat egasi
      allow delete: if isSignedIn() && existingData().uid == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════
    // 3. XIZMATLAR (Services) — Faqat o'qish
    // ═══════════════════════════════════════════════════════
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════
    // 4. BRONLAR (Bookings)
    // ═══════════════════════════════════════════════════════
    match /bookings/{bookingId} {
      // Faqat tizimga kirganlar o'qiy oladi
      allow read: if isSignedIn();
      
      // Yaratish: clientUid = auth.uid, barberUid kerak, status = "pending"
      allow create: if isSignedIn() 
                    && incomingData().clientUid == request.auth.uid
                    && incomingData().keys().hasAll(['clientUid', 'barberUid', 'service', 'status'])
                    && incomingData().status == 'pending';
      
      // Yangilash: faqat shu bronning mijozi YOKI usta (barberUid)
      // clientUid va barberUid ni o'zgartirish mumkin emas
      allow update: if isSignedIn() 
                    && (existingData().clientUid == request.auth.uid 
                        || existingData().barberUid == request.auth.uid)
                    && incomingData().clientUid == existingData().clientUid
                    && incomingData().barberUid == existingData().barberUid
                    && incomingData().status in ['pending', 'confirmed', 'cancelled', 'completed'];
                    
      // O'chirish: faqat mijoz
      allow delete: if isSignedIn() && existingData().clientUid == request.auth.uid;
    }
    
    // ═══════════════════════════════════════════════════════
    // 5. BOSHQA HAMMA NARSA — TAQIQLANGAN
    // ═══════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
